# Copy to ~/.dbt/profiles.yml (or set DBT_PROFILES_DIR) and fill in secrets.
# This targets Databricks (what you run today). The SAME models run unchanged
# on Azure Databricks — only host/http_path/catalog change. See
# docs/azure_migration_plan.md.

tapmad_reconciliation:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: tapmad            # Unity Catalog name (hive_metastore if no UC)
      schema: reconciliation     # default target schema
      host: "{{ env_var('DATABRICKS_HOST') }}"          # adb-xxxx.azuredatabricks.net
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}" # /sql/1.0/warehouses/xxxx
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 4

    # Optional: a prod target pointing at the prod warehouse / catalog.
    prod:
      type: databricks
      catalog: tapmad_prod
      schema: reconciliation
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH_PROD') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 8
